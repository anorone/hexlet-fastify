extends ../layouts/index

block content
  if error
    p= error.message
  form(action=route('addCourse') method='post')
    div
      label Title:
        input(
          type='text'
          name='title'
          value=values.title
          required=true
        )
    div
      label Description:
        textarea(
          name='description'
        )= values.description
    input(type='submit' value='Add')
